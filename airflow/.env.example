# ============================================
# Service: Airflow
# Copy to .env and fill in YOUR_* / GENERATE_ME_* values.
# The installer generates these automatically.
# ============================================

# Global Variables (synced from stacks/global.env)
CONF=YOUR_INSTALL_DIR/conf
TZ=America/New_York
IP=YOUR_SERVER_IP
HOMEPAGE_GROUP=Data

# Airflow Configuration
AIRFLOW_IMAGE_NAME=apache/airflow:3.1.3
DOCKER_GID=DETECT_ME_DOCKER_GID
AIRFLOW_UID=1000
AIRFLOW_PORT=8080

# Airflow Secrets
# Generate with:
#   Fernet: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   Secret/JWT: openssl rand -base64 42
AIRFLOW_FERNET_KEY=GENERATE_ME_FERNET_KEY
AIRFLOW_SECRET_KEY=GENERATE_ME_SECRET
AIRFLOW_JWT_SECRET=GENERATE_ME_SECRET

# Database Configuration (shared postgres container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Airflow Web UI Credentials
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin
