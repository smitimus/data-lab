# ============================================
# Service: superset
# Copy to .env and fill in YOUR_* / GENERATE_ME_* values.
# ============================================

# Global Variables
CONF=YOUR_CONF_DIR
TZ=America/New_York
IP=YOUR_SERVER_IP
HOMEPAGE_GROUP=Data

# Superset Configuration
SUPERSET_PORT=8088
# Generate with: openssl rand -base64 42
SUPERSET_SECRET_KEY=GENERATE_ME_SECRET
SUPERSET_ADMIN_PASSWORD=admin  # service-specific
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
