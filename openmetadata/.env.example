# ============================================
# Service: OpenMetadata
# Copy to .env and fill in YOUR_* / GENERATE_ME_* values.
# ============================================

# Global Variables
CONF=YOUR_INSTALL_DIR/conf
TZ=America/New_York
IP=YOUR_SERVER_IP
HOMEPAGE_GROUP=Data

# Airflow Configuration (must match stacks/airflow/.env)
AIRFLOW_IMAGE_NAME=apache/airflow:3.1.3
DOCKER_GID=DETECT_ME_DOCKER_GID
AIRFLOW_UID=1000
AIRFLOW_PORT=8080
AIRFLOW_FERNET_KEY=GENERATE_ME_FERNET_KEY
AIRFLOW_SECRET_KEY=GENERATE_ME_SECRET
AIRFLOW_JWT_SECRET=GENERATE_ME_SECRET
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin

# OpenMetadata Configuration
OPENMETADATA_PORT=8585
OPENMETADATA_ADMIN_EMAIL=admin@open-metadata.org  # service-specific
OPENMETADATA_ADMIN_PASSWORD=admin  # service-specific

# Cross-stack credentials for seeding connections
SUPERSET_ADMIN_PASSWORD=admin  # cross-stack credential
VERISIM_POSTGRES_USER=verisim  # cross-stack credential
VERISIM_POSTGRES_PASSWORD=verisim  # cross-stack credential
