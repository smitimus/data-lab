# ============================================
# Service: minio (S3-compatible object storage)
# Copy to .env. Most values are synced from global.env (CONF, TZ, IP,
# HOMEPAGE_GROUP, S3_ACCESS_KEY, S3_SECRET_KEY, S3_BUCKET, S3_REGION).
# ============================================

# Global Variables (synced from global.env)
CONF=YOUR_CONF_DIR
TZ=America/New_York
IP=YOUR_SERVER_IP
HOMEPAGE_GROUP=Data

# MinIO S3 credentials (synced from global.env)
S3_ACCESS_KEY=YOUR_S3_ACCESS_KEY
S3_SECRET_KEY=YOUR_S3_SECRET_KEY
S3_BUCKET=reports
S3_REGION=us-east-1

# Ports (service-specific; have sensible defaults if omitted)
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
