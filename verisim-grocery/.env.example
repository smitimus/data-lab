# ============================================
# Service: verisim-grocery (release mode)
# Pulls smiti/verisim-grocery from Docker Hub.
# For development, use verisim/switch.sh dev instead.
# Copy to .env and fill in YOUR_* values.
# ============================================

# Global Variables
CONF=YOUR_CONF_DIR
TZ=America/New_York
IP=YOUR_SERVER_IP
HOMEPAGE_GROUP=Data

# Verisim Grocery Configuration
VERISIM_POSTGRES_PORT=5499
VERISIM_API_PORT=8010
VERISIM_UI_PORT=8501
VERISIM_POSTGRES_USER=verisim
VERISIM_POSTGRES_PASSWORD=verisim
VERISIM_GROCERY_DB=grocery
