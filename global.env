# ============================================
# Global Docker Environment Variables
# ============================================
# These variables are shared by all services.
# Use global-env-sync.py to push changes to all service .env files:
#   cd stacks && python global-env-sync.py

# Base Paths
CONF=/opt/data-lab/_conf               # ${CONF} - Configuration directory
STACKS=/opt/data-lab          # ${STACKS} - Stack install directory

# System Configuration
TZ=America/New_York              # ${TZ} - Timezone

# Network Configuration
IP=192.168.1.4                # ${IP} - Server IP address

# Homepage Configuration
HOMEPAGE_GROUP=Data              # ${HOMEPAGE_GROUP} - Homepage dashboard group name

# PostgreSQL Shared Credentials (EDW — used by postgres, superset, dbt-docs, meltano)
POSTGRES_USER=postgres           # ${POSTGRES_USER} - Shared EDW superuser
POSTGRES_PASSWORD=postgres       # ${POSTGRES_PASSWORD} - Shared EDW password

# MinIO S3-compatible storage (data-lab#35 executive report export target)
# Internal endpoint http://minio:9000 (Docker DNS on postgres_network).
# Console (web UI) exposed on host at http://${IP}:9001.
# DEV DEFAULTS — change before any non-local deployment.
S3_ENDPOINT=http://minio:9000   # ${S3_ENDPOINT} - MinIO service URL (internal)
S3_ACCESS_KEY=admin                # ${S3_ACCESS_KEY} - MinIO root user (default)
S3_SECRET_KEY=adminadmin            # ${S3_SECRET_KEY} - MinIO root password (>=8 chars; MinIO enforces min 8, so literal 'admin' would fail to start)
S3_BUCKET=reports                # ${S3_BUCKET} - bucket for exported reports
S3_REGION=us-east-1             # ${S3_REGION} - bucket region (cosmetic for MinIO)
