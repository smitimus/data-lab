# ============================================
# Global Docker Environment Variables
# ============================================
# These variables are shared by all services.
# Use global-env-sync.py to push changes to all service .env files:
#   cd stacks && python global-env-sync.py

# Base Paths
CONF=YOUR_CONF_DIR               # ${CONF} - Configuration directory
STACKS=YOUR_INSTALL_DIR          # ${STACKS} - Stack install directory

# System Configuration
TZ=America/New_York              # ${TZ} - Timezone

# Network Configuration
IP=YOUR_SERVER_IP                # ${IP} - Server IP address

# Homepage Configuration
HOMEPAGE_GROUP=Data              # ${HOMEPAGE_GROUP} - Homepage dashboard group name
