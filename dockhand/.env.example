# ============================================
# Service: dockhand
# Copy to .env and fill in YOUR_* / GENERATE_ME_* values.
# ============================================

# Global Variables
CONF=YOUR_INSTALL_DIR/conf
TZ=America/New_York
IP=YOUR_SERVER_IP
HOMEPAGE_GROUP=Data

# Dockhand Configuration
# Host path for Dockhand data — must match host-side of ${CONF}/dockhand:/app/data mount
HOST_DATA_DIR=YOUR_INSTALL_DIR/conf/dockhand  # service-specific
# Generate with: openssl rand -base64 32
# Keep stable — changing it loses stored credentials
ENCRYPTION_KEY=GENERATE_ME_ENCRYPTION_KEY  # service-specific
